APP_NAME="Haze Tool API"
APP_VERSION="0.1.0"
ENVIRONMENT="development"
DEBUG=false

DATABASE_URL="mysql+pymysql://haze:change-me@127.0.0.1:3306/haze?charset=utf8mb4"

JWT_SECRET_KEY="replace-with-a-long-random-secret"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

INITIAL_ADMIN_NAME="admin"
INITIAL_ADMIN_PHONE="13800138000"
INITIAL_ADMIN_EMAIL="admin@example.com"
INITIAL_ADMIN_PASSWORD="replace-with-a-strong-admin-password"
INITIAL_ADMIN_DEPARTMENT="System Administration"

CORS_ORIGINS='["http://localhost:3000","http://127.0.0.1:3000"]'
LOCAL_STORAGE_DIR="./storage"

# Public MCP Gateway base URL. Production example: https://skills.paiwo188.com
GATEWAY_PUBLIC_BASE_URL="http://127.0.0.1:8001"
# Production example: DOWNLOAD_PUBLIC_BASE_URL="https://skills.paiwo188.com"
DOWNLOAD_PUBLIC_BASE_URL="http://127.0.0.1:8000"
DOWNLOAD_LINK_EXPIRE_MINUTES=30

# Docker pre-pull on startup (recommended: true in production)
MCP_DOCKER_PREPULL=false
MCP_DOCKER_IMAGES='["node:20-slim","python:3.12-slim"]'

REGISTRY_URL=localhost:5000
REGISTRY_PUSH_ENABLED=true
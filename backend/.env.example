APP_NAME="Haze Tool API"
APP_VERSION="0.1.0"
ENVIRONMENT="development"
DEBUG=false

DATABASE_URL="mysql+pymysql://haze:change-me@127.0.0.1:3306/haze?charset=utf8mb4"

JWT_SECRET_KEY="replace-with-a-long-random-secret"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

INITIAL_ADMIN_NAME="admin"
INITIAL_ADMIN_PHONE="13800138000"
INITIAL_ADMIN_EMAIL="admin@example.com"
INITIAL_ADMIN_PASSWORD="replace-with-a-strong-admin-password"
INITIAL_ADMIN_DEPARTMENT="System Administration"

CORS_ORIGINS='["http://localhost:3000","http://127.0.0.1:3000"]'
LOCAL_STORAGE_DIR="./storage"
